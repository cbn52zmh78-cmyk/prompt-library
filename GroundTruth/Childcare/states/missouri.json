          }
        },
        {
          "fact_id": "missouri-childcare-background-checks-3",
          "category": "background_checks",
          "text": "Missouri child care licensing — (M) The provider shall request the results of a criminal background check for child care staff members as required by 5 CSR 25-600.",
          "citation": {
            "source": "Missouri 5 CSR 25-500 Staff/Child Ratios",
            "url": "https://www.sos.mo.gov/adrules/csr/current/5csr/5c25-500.pdf",
            "agency": "Missouri 5 CSR 25-500 Staff/Child Ratios",
            "category": "background_checks",
            "tier": "secondary",
            "retrieved_date": "2026-06-19"
          },
          "grade": {
            "status": "FOUND",
            "tier": "secondary",
            "category": "background_checks"
          }
        },
        {
          "fact_id": "missouri-childcare-background-checks-4",
          "category": "background_checks",
          "text": "Missouri child care licensing — (P) The child care provider shall conduct a Family Care Safety Registry screening prior to employment for any newly hired child care staff member who has a qualifying criminal background check result.",
          "citation": {
            "source": "Missouri 5 CSR 25-500 Staff/Child Ratios",
