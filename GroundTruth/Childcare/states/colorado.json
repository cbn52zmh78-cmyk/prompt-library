      "facts": [
        {
          "fact_id": "colorado-childcare-staff-qualifications-1",
          "category": "staff_qualifications",
          "text": "Colorado child care licensing — A total of 6 semester hours or equivalent quarter hours in 2 classes: health, nutrition, and safety; and administration of a child care center which must be at least 3 semester or equivalent quarter hours; or Directors of public school preschools must attend a department-approved course of training in nutrition and implementation of rules regulating child care.",
          "citation": {
            "source": "Colorado 7 CCR 1-3.5 (SOS admin-code PDF)",
            "url": "https://www.sos.state.co.us/CCR/GenerateRulePdf.do?ruleVersionId=973",
            "agency": "Colorado 7 CCR 1-3.5 (SOS admin-code PDF)",
            "category": "staff_qualifications",
            "tier": "tertiary",
            "retrieved_date": "2026-06-19"
          },
          "grade": {
            "status": "FOUND",
            "tier": "tertiary",
            "category": "staff_qualifications"
          }
        },
        {
          "fact_id": "colorado-childcare-staff-qualifications-2",
          "category": "staff_qualifications",
          "text": "Colorado child care licensing — The experience requirements for the director of a large center must be met by completion of the following amount of work experience in a child development program, which includes working with a group of children in such programs as a preschool, child care center, kindergarten, or Head Start program: 1.",
          "citation": {
            "source": "Colorado 7 CCR 1-3.5 (SOS admin-code PDF)",
            "url": "https://www.sos.state.co.us/CCR/GenerateRulePdf.do?ruleVersionId=973",
            "agency": "Colorado 7 CCR 1-3.5 (SOS admin-code PDF)",
            "category": "staff_qualifications",
            "tier": "tertiary",
            "retrieved_date": "2026-06-19"
          },
          "grade": {
            "status": "FOUND",
            "tier": "tertiary",
            "category": "staff_qualifications"
          }
        },
        {
          "fact_id": "colorado-childcare-staff-qualifications-3",
          "category": "staff_qualifications",
          "text": "Colorado child care licensing — Staff aides must be at least 16 years of age, must work directly under the supervision of the director or a toddler group leader, and must have completed 8 hours of orientation at the toddler nursery.",
          "citation": {
            "source": "Colorado 7 CCR 1-3.5 (SOS admin-code PDF)",
            "url": "https://www.sos.state.co.us/CCR/GenerateRulePdf.do?ruleVersionId=973",
            "agency": "Colorado 7 CCR 1-3.5 (SOS admin-code PDF)",
            "category": "staff_qualifications",
            "tier": "tertiary",
            "retrieved_date": "2026-06-19"
          },
          "grade": {
            "status": "FOUND",
            "tier": "tertiary",
            "category": "staff_qualifications"
          }
        },
        {
          "fact_id": "colorado-childcare-staff-qualifications-4",
          "category": "staff_qualifications",
          "text": "Colorado child care licensing — All child care staff designated by the center director to give medications must complete the 4- hour Department-approved medication administration training and have current first aid and universal precautions training prior to administering medication.",
          "citation": {
            "source": "Colorado 7 CCR 1-3.5 (SOS admin-code PDF)",
            "url": "https://www.sos.state.co.us/CCR/GenerateRulePdf.do?ruleVersionId=973",
            "agency": "Colorado 7 CCR 1-3.5 (SOS admin-code PDF)",
            "category": "staff_qualifications",
            "tier": "tertiary",
            "retrieved_date": "2026-06-19"
          },
          "grade": {
            "status": "FOUND",
            "tier": "tertiary",
            "category": "staff_qualifications"
          }
        },
        {
          "fact_id": "colorado-childcare-staff-qualifications-5",
          "category": "staff_qualifications",
          "text": "Colorado child care licensing — If the center engages in special activities away from the child care facility, the staff member responsible for the activity must possess evidence of appropriate experience, training, and/or certification in the program specialty.",
          "citation": {
            "source": "Colorado 7 CCR 1-3.5 (SOS admin-code PDF)",
            "url": "https://www.sos.state.co.us/CCR/GenerateRulePdf.do?ruleVersionId=973",
            "agency": "Colorado 7 CCR 1-3.5 (SOS admin-code PDF)",
            "category": "staff_qualifications",
            "tier": "tertiary",
            "retrieved_date": "2026-06-19"
          },
          "grade": {
            "status": "FOUND",
            "tier": "tertiary",
            "category": "staff_qualifications"
          }
        },
        {
          "fact_id": "colorado-childcare-staff-qualifications-6",
          "category": "staff_qualifications",
          "text": "Colorado child care licensing — Each special activity shall be under the supervision of a staff member who shall possess evidence of appropriate experience, training and/or certification in the program specialty.",
          "citation": {
            "source": "Colorado 7 CCR 1-3.5 (SOS admin-code PDF)",
            "url": "https://www.sos.state.co.us/CCR/GenerateRulePdf.do?ruleVersionId=973",
            "agency": "Colorado 7 CCR 1-3.5 (SOS admin-code PDF)",
            "category": "staff_qualifications",
            "tier": "tertiary",
            "retrieved_date": "2026-06-19"
          },
          "grade": {
            "status": "FOUND",
            "tier": "tertiary",
            "category": "staff_qualifications"
          }
        },
        {
          "fact_id": "colorado-childcare-staff-qualifications-7",
          "category": "staff_qualifications",
          "text": "Colorado child care licensing — The hiking or backpacking supervisor must be at least 21 years old, shall hold a current American Red Cross First Aid/CPR/AED Certificate for schools an communities or equivalent, and shall have verifiable experience leading a group in backpacking at the elevation, terrain and climate where the hike is to take place.",
          "citation": {
            "source": "Colorado 7 CCR 1-3.5 (SOS admin-code PDF)",
            "url": "https://www.sos.state.co.us/CCR/GenerateRulePdf.do?ruleVersionId=973",
            "agency": "Colorado 7 CCR 1-3.5 (SOS admin-code PDF)",
            "category": "staff_qualifications",
            "tier": "tertiary",
            "retrieved_date": "2026-06-19"
          },
          "grade": {
            "status": "FOUND",
