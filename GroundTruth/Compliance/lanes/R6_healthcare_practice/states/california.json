      "cited_facts": [
        {
          "fact_id": "R6-CA-CMIA-001",
          "text": "A provider, health care service plan, or contractor shall not disclose medical information regarding a patient without first obtaining an authorization, except as provided in §56.10(b) or (c).",
          "status": "FOUND",
          "citation": {
            "source": "Cal. Civ. Code §56.10(a)",
            "url": "https://leginfo.legislature.ca.gov/faces/codes_displaySection.xhtml?sectionNum=56.10.&lawCode=CIV",
            "jurisdiction": "California",
            "tier": "statute_primary",
            "retrieved_date": "2026-06-19"
          }
        },
        {
          "fact_id": "R6-CA-CMIA-002",
          "text": "Except as authorized, a provider, plan, contractor, or affiliate shall not intentionally share, sell, use for marketing, or otherwise use medical information for a purpose not necessary to provide health care services.",
          "status": "FOUND",
          "citation": {
            "source": "Cal. Civ. Code §56.10(d)",
            "url": "https://leginfo.legislature.ca.gov/faces/codes_displaySection.xhtml?sectionNum=56.10.&lawCode=CIV",
            "jurisdiction": "California",
            "tier": "statute_primary",
            "retrieved_date": "2026-06-19"
          }
        },
        {
          "fact_id": "R6-CA-CMIA-003",
          "text": "CMIA permits disclosure to other providers for diagnosis or treatment, to payers for payment determination, and to other listed entities under §56.10(c) without patient authorization.",
          "status": "FOUND",
          "citation": {
            "source": "Cal. Civ. Code §56.10(c)(1)-(3)",
            "url": "https://leginfo.legislature.ca.gov/faces/codes_displaySection.xhtml?sectionNum=56.10.&lawCode=CIV",
            "jurisdiction": "California",
            "tier": "statute_primary",
            "retrieved_date": "2026-06-19"
          }
        },
        {
          "fact_id": "R6-CA-CMIA-004",
          "text": "Disclosures to employee welfare benefit plans must comply with written authorization and federal HIPAA Part 164 restrictions; information may not be further used in violation of CMIA or 45 CFR Part 164.",
          "status": "FOUND",
          "citation": {
            "source": "Cal. Civ. Code §56.10(c)(21)",
