        },
        {
          "fact_id": "R6-CA-CMIA-005",
          "text": "Authorization for release must be in 14-point type (or handwritten), separately executed, specify uses/limitations/recipients, and expire within one year unless a longer period is requested or clinical-trial exception applies.",
