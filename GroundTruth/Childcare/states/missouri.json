    "staff_qualifications": {
      "status": "HARVESTED",
      "fact_count": 5,
      "facts": [
        {
          "fact_id": "missouri-childcare-staff-qualifications-1",
          "category": "staff_qualifications",
          "text": "Missouri child care licensing — If the facility operates less than forty (40) hours per week, the center director or group child care home provider shall be on duty at least fifty percent (50%) of the operating hours.",
          "citation": {
            "source": "Missouri 5 CSR 25-500 Staff/Child Ratios",
            "url": "https://www.sos.mo.gov/adrules/csr/current/5csr/5c25-500.pdf",
            "agency": "Missouri 5 CSR 25-500 Staff/Child Ratios",
            "category": "staff_qualifications",
            "tier": "secondary",
            "retrieved_date": "2026-06-19"
          },
          "grade": {
            "status": "FOUND",
            "tier": "secondary",
            "category": "staff_qualifications"
          }
        },
        {
          "fact_id": "missouri-childcare-staff-qualifications-2",
          "category": "staff_qualifications",
          "text": "Missouri child care licensing — (A) The center director, group child care home provider, all other caregivers, and those volunteers who are counted in staff/child ratios shall obtain at least twelve (12) clock hours of child-care related training during each calendar year.",
          "citation": {
            "source": "Missouri 5 CSR 25-500 Staff/Child Ratios",
            "url": "https://www.sos.mo.gov/adrules/csr/current/5csr/5c25-500.pdf",
            "agency": "Missouri 5 CSR 25-500 Staff/Child Ratios",
            "category": "staff_qualifications",
            "tier": "secondary",
            "retrieved_date": "2026-06-19"
          },
          "grade": {
            "status": "FOUND",
            "tier": "secondary",
            "category": "staff_qualifications"
          }
        },
        {
          "fact_id": "missouri-childcare-staff-qualifications-3",
          "category": "staff_qualifications",
          "text": "Missouri child care licensing — The child care provider, group child care home provider, child care staff members, and volunteers in a group child care home or child care center shall complete safe sleep training described in subsection (4)(A) of this rule prior to licensure.",
          "citation": {
            "source": "Missouri 5 CSR 25-500 Staff/Child Ratios",
            "url": "https://www.sos.mo.gov/adrules/csr/current/5csr/5c25-500.pdf",
            "agency": "Missouri 5 CSR 25-500 Staff/Child Ratios",
            "category": "staff_qualifications",
            "tier": "secondary",
            "retrieved_date": "2026-06-19"
          },
          "grade": {
            "status": "FOUND",
            "tier": "secondary",
            "category": "staff_qualifications"
          }
        },
        {
          "fact_id": "missouri-childcare-staff-qualifications-4",
          "category": "staff_qualifications",
          "text": "Missouri child care licensing — The child care provider, group child care home provider, child care staff members, and volunteers shall complete safe sleep training described in subsection (4)(A) of this rule within thirty (30) days of employment or volunteering at the facility.",
          "citation": {
            "source": "Missouri 5 CSR 25-500 Staff/Child Ratios",
            "url": "https://www.sos.mo.gov/adrules/csr/current/5csr/5c25-500.pdf",
            "agency": "Missouri 5 CSR 25-500 Staff/Child Ratios",
            "category": "staff_qualifications",
            "tier": "secondary",
            "retrieved_date": "2026-06-19"
          },
          "grade": {
            "status": "FOUND",
            "tier": "secondary",
            "category": "staff_qualifications"
          }
        },
        {
          "fact_id": "missouri-childcare-staff-qualifications-5",
          "category": "staff_qualifications",
          "text": "Missouri child care licensing — (E) An adult with a current lifeguard training certificate, in - cluding infant/child cardiopulmonary resuscitation (CPR) train- ing, shall be on duty at all times when a swimming or wading pool containing a depth of forty-eight inches (48\") or more of water is being used.",
          "citation": {
            "source": "Missouri 5 CSR 25-500 Staff/Child Ratios",
            "url": "https://www.sos.mo.gov/adrules/csr/current/5csr/5c25-500.pdf",
            "agency": "Missouri 5 CSR 25-500 Staff/Child Ratios",
            "category": "staff_qualifications",
            "tier": "secondary",
            "retrieved_date": "2026-06-19"
          },
          "grade": {
            "status": "FOUND",
            "tier": "secondary",
            "category": "staff_qualifications"
          }
        }
      ]
