          "fact_id": "colorado-childcare-background-checks-1",
          "category": "background_checks",
          "text": "Colorado child care licensing — For the purposes of all child care licensing rules, the terms \"child battering\", \"child abuse\", \"child molesting\", and \"child neglect\" are terms to be considered within the definition of abuse set forth in Section 19-1-103, C.",
          "citation": {
            "source": "Colorado 7 CCR 1-3.5 (SOS admin-code PDF)",
            "url": "https://www.sos.state.co.us/CCR/GenerateRulePdf.do?ruleVersionId=973",
            "agency": "Colorado 7 CCR 1-3.5 (SOS admin-code PDF)",
            "category": "background_checks",
